# Copia questo file in ".env" e compila i valori.
# Con Vite le variabili devono iniziare con VITE_ per essere leggibili dal codice.

# Chiave OMDB (registrazione gratuita: https://www.omdbapi.com/apikey.aspx)
VITE_OMDB_API_KEY=

# Token JWT del backend striveschool (recensioni). NON è la apikey OMDB. Facoltativo.
VITE_STRIVE_BEARER=
